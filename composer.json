{
	"name": "nikolaos-mantas/withdrawal-button",
	"description": "WordPress withdrawal request form plugin",
	"type": "wordpress-plugin",
	"license": "proprietary",
	"authors": [
		{
			"name": "Nikolaos Mantas",
			"email": "info@nmantas.eu",
			"homepage": "https://nmantas.eu"
		}
	],
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"gettext/gettext": "5.7",
		"doctrine/instantiator": "^1.5.0"
	},
	"config": {
		"platform": {
			"php": "7.4.33"
		}
	},
	"scripts": {
		"test": "phpunit",
		"translations": "php bin/compile-translations.php",
